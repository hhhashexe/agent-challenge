{
  "version": "0.1",
  "ops": [
    {
      "id": "shieldnet-agent",
      "type": "container/run",
      "args": {
        "image": "ghcr.io/hhhashexe/shieldnet-eliza-agent:latest",
        "expose": 3000,
        "env": {
          "OPENAI_API_KEY": "nosana",
          "OPENAI_BASE_URL": "https://inference.nosana.io/v1",
          "MODEL_PROVIDER": "openai",
          "MODEL_NAME": "Qwen/Qwen2.5-72B-Instruct-AWQ",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production"
        },
        "gpu": true
      }
    }
  ]
}
